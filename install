#!/usr/bin/env bash
set -euo pipefail

SRC_DIR=""
REPO_RAW="https://raw.githubusercontent.com/Rghyga/autosc/master"
REPO_ARCHIVE="https://codeload.github.com/Rghyga/autosc/tar.gz/refs/heads/master"
BASE_DIR="/etc/katsu-xray"
BIN_DIR="/usr/local/sbin"
GITHUB_USER="Rghyga"
GITHUB_REPO="autosc"
GITHUB_BRANCH="master"
DEFAULT_ACME_EMAIL="admin@akademi-belajar.my.id"
DEFAULT_ACME_MODE="semi-permanent"
WORKDIR=""

red='\033[0;31m'
green='\033[0;32m'
yellow='\033[1;33m'
cyan='\033[0;36m'
white='\033[1;37m'
nc='\033[0m'

need_root(){ [ "$EUID" -eq 0 ] || { echo -e "${red}Please run as root${nc}"; exit 1; }; }
os_check(){ . /etc/os-release; case "$ID" in ubuntu|debian) :;; *) echo -e "${red}Unsupported OS: $ID${nc}"; exit 1;; esac; }
cleanup(){ [ -n "${WORKDIR:-}" ] && [ -d "$WORKDIR" ] && rm -rf "$WORKDIR"; }
trap cleanup EXIT

line(){ printf '%*s\n' 70 '' | tr ' ' '-'; }
print_banner(){
  clear
  echo -e "${cyan}+$(line | tr -d '\n')+${nc}"
  printf "${cyan}|${white} %-70s ${cyan}|${nc}\n" "KATSUDEV XRAY ONLY INSTALLER"
  printf "${cyan}|${nc} %-70s ${cyan}|${nc}\n" "Business Grade VPN Panel - VMess / VLESS / Trojan"
  printf "${cyan}|${nc} %-70s ${cyan}|${nc}\n" "GitHub: ${GITHUB_USER}/${GITHUB_REPO} (${GITHUB_BRANCH})"
  echo -e "${cyan}+$(line | tr -d '\n')+${nc}"
  echo
}
box_line(){ printf "${cyan}|${nc} %-70s ${cyan}|${nc}\n" "$1"; }
ask_domain(){
  echo -e "${cyan}+$(line | tr -d '\n')+${nc}"
  box_line "SSL / ACME Configuration"
  echo -e "${cyan}+$(line | tr -d '\n')+${nc}"
  printf "${cyan}|${nc} %s" "Email ACME permanen di script : ${DEFAULT_ACME_EMAIL}"
  printf "\n${cyan}|${nc} %s" "Masukkan domain untuk install ini: "
  read -r DOMAIN
  DOMAIN="${DOMAIN// /}"
  echo
  echo -e "${cyan}+$(line | tr -d '\n')+${nc}"
  [ -n "$DOMAIN" ] || { echo -e "${red}Domain wajib diisi.${nc}"; exit 1; }
  ACME_MODE="$DEFAULT_ACME_MODE"
  ACME_EMAIL="$DEFAULT_ACME_EMAIL"
}
step(){ printf "${yellow}*${nc} %s ... " "$1"; }
ok(){ echo -e "${green}[OK]${nc}"; }

install_pkgs(){
  apt update -y
  DEBIAN_FRONTEND=noninteractive apt install -y curl wget unzip git jq python3 nginx socat cron ca-certificates lsb-release uuid-runtime vnstat fail2ban tar
}
setup_dirs(){
  mkdir -p "$BASE_DIR"/{lib,data,backups}
  mkdir -p /etc/xray /var/log/xray /var/www/openclash /var/www/html
  mkdir -p /etc/katsu-xray/accounts/{vmess,vless,trojan}
  mkdir -p /etc/katsu-xray/quota/{vmess,vless,trojan}
  mkdir -p /etc/katsu-xray/iplimit/{vmess,vless,trojan}
}
fetch_repo(){
  WORKDIR="$(mktemp -d /tmp/katsudev.XXXXXX)"
  curl -fsSL "$REPO_ARCHIVE" -o "$WORKDIR/repo.tar.gz"
  tar -xzf "$WORKDIR/repo.tar.gz" -C "$WORKDIR"
  SRC_DIR="$(find "$WORKDIR" -maxdepth 1 -type d -name "${GITHUB_REPO}-*" | head -n1)"
  [ -n "$SRC_DIR" ] || { echo "Gagal menemukan source directory dari archive repo"; return 1; }
}
fetch_files(){
  install -m 755 "$SRC_DIR"/bin/* "$BIN_DIR"/
  cp -rf "$SRC_DIR"/lib/. "$BASE_DIR/lib/"
  cp -rf "$SRC_DIR"/templates/xray/config.json /etc/xray/config.json
  cp -rf "$SRC_DIR"/templates/nginx/xray.conf /etc/nginx/conf.d/xray.conf
  cp -rf "$SRC_DIR"/templates/systemd/katsu-xray.service /etc/systemd/system/katsu-xray.service
  find "$BIN_DIR" -maxdepth 1 -type f \( -name 'menu*' -o -name 'xray-*' \) -exec chmod +x {} \;
  find "$BASE_DIR/lib" -maxdepth 1 -type f -name '*.sh' -exec chmod +x {} \;
}
write_env(){
  local server_ip
  server_ip=$(curl -fsSL ipv4.icanhazip.com || hostname -I | awk '{print $1}')
  cat > /etc/katsu-xray/config.env <<EOC
ACME_MODE=${ACME_MODE}
ACME_EMAIL=${ACME_EMAIL}
DOMAIN=${DOMAIN}
SERVER_IP=${server_ip}
XRAY_TLS_PORT=443
XRAY_NTLS_PORT=80
XRAY_GRPC_PORT=443
OPENCLASH_PORT=81
VMESS_WS_PATH=/vmess
VLESS_WS_PATH=/vless
TROJAN_WS_PATH=/trojan
VMESS_GRPC_SERVICE=vmess-grpc
VLESS_GRPC_SERVICE=vless-grpc
TROJAN_GRPC_SERVICE=trojan-grpc
EOC
}
render_nginx(){ sed -i "s|__DOMAIN__|${DOMAIN}|g" /etc/nginx/conf.d/xray.conf; }
install_xray(){ bash -c "$(curl -fsSL https://github.com/XTLS/Xray-install/raw/main/install-release.sh)" @ install; }
issue_ssl(){
  curl -fsSL https://get.acme.sh | sh -s email="$ACME_EMAIL"
  ~/.acme.sh/acme.sh --set-default-ca --server letsencrypt
  mkdir -p /var/www/html
  ~/.acme.sh/acme.sh --issue -d "$DOMAIN" -w /var/www/html --keylength ec-256 --force
  ~/.acme.sh/acme.sh --install-cert -d "$DOMAIN" --ecc --fullchain-file /etc/xray/xray.crt --key-file /etc/xray/xray.key
  chmod 600 /etc/xray/xray.key
}
validate_config(){ nginx -t && xray -test -config /etc/xray/config.json >/dev/null; }
enable_services(){
  systemctl daemon-reload
  systemctl enable nginx vnstat fail2ban xray >/dev/null 2>&1 || true
  systemctl restart nginx
  systemctl restart vnstat || true
  systemctl restart fail2ban || true
  systemctl restart xray
  ln -sf /usr/local/sbin/menu /usr/local/bin/menu
}
finish_screen(){
  echo
  echo -e "${cyan}+$(line | tr -d '\n')+${nc}"
  box_line "INSTALLATION COMPLETE"
  box_line "Email ACME         : ${ACME_EMAIL}"
  box_line "Mode ACME          : ${ACME_MODE}"
  box_line "Domain Install Ini : ${DOMAIN}"
  box_line "OpenClash Web      : https://${DOMAIN}:81/"
  box_line "Menu Command       : menu"
  echo -e "${cyan}+$(line | tr -d '\n')+${nc}"
  echo
  echo -e "${white}One-click install:${nc}"
  echo "apt update && apt install wget curl -y && wget -qO install https://raw.githubusercontent.com/Rghyga/autosc/master/install && chmod +x install && ./install"
}
main(){
  need_root
  os_check
  print_banner
  ask_domain
  echo
  step "Update package index and install dependencies"; install_pkgs; ok
  step "Menyiapkan direktori autoscript"; setup_dirs; ok
  step "Mengunduh source autoscript dari GitHub"; fetch_repo; ok
  step "Menyalin binary, library, dan template"; fetch_files; ok
  step "Menulis environment konfigurasi"; write_env; ok
  step "Render konfigurasi nginx untuk domain"; render_nginx; ok
  step "Install core Xray"; install_xray; ok
  step "Issue SSL certificate via ACME"; issue_ssl; ok
  step "Validasi konfigurasi Nginx dan Xray"; validate_config; ok
  step "Enable dan restart seluruh service"; enable_services; ok
  finish_screen
}
main "$@"
